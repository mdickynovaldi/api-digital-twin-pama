{
  "name": "api-digital-twin-pama",
  "version": "1.0.0",
  "description": "GeoPoint & volumetric analysis API (based on Unity RuntimeVolumetricVisualizer) — Hono + Prisma + Scalar, deployable to Vercel + Neon.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "prisma generate",
    "vercel-build": "prisma generate",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx test/smoke.ts",
    "test:integration": "tsx test/integration.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-openapi": "^1.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/hono-api-reference": "^0.11.4",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
