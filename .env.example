# --- Neon / Postgres connection --------------------------------------------
# Pooled connection (used by the app at runtime via the Neon driver adapter).
# In Neon, copy the "Pooled connection" string (host contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct (unpooled) connection — used by Prisma migrations / db push.
# In Neon, copy the "Direct connection" string (host has NO "-pooler").
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Local dev only (Vercel sets this automatically in production).
NODE_ENV="development"
# PORT=3000
